# npm 二进制包镜像（仅供 source，勿放入 .env.local）
# 用法: source scripts/npm-binary-mirrors.env && npm install

export npm_config_disturl=https://npmmirror.com/mirrors/node
export npm_config_electron_mirror=https://npmmirror.com/mirrors/electron/
export npm_config_sharp_binary_host=https://npmmirror.com/mirrors/sharp
export npm_config_sharp_libvips_binary_host=https://npmmirror.com/mirrors/sharp-libvips
