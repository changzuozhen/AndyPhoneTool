{
  "name": "andyphonetool",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~57.0.4",
    "expo-camera": "^57.0.1",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "setup:cn": "bash scripts/setup-china-env.sh",
    "aptool": "node packages/aptool/dist/index.js",
    "aptool:dev": "npm run dev -w @andyphonetool/aptool",
    "aptool:build": "npm run build -w @andyphonetool/aptool",
    "start": "EXPO_NO_TELEMETRY=1 expo start",
    "start:cn": "EXPO_NO_TELEMETRY=1 EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start",
    "android": "EXPO_NO_TELEMETRY=1 expo start --android",
    "ios": "EXPO_NO_TELEMETRY=1 expo start --ios",
    "web": "EXPO_NO_TELEMETRY=1 expo start --web",
    "prebuild:android": "EXPO_NO_TELEMETRY=1 expo prebuild --platform android --clean"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
}
